# Generated by generate-secrets.sh — do not edit manually
# Run: ./generate-secrets.sh <SERVER_IP> [REALITY_COVER_DOMAIN] [CREDENTIALS_DOMAIN]

SERVER_IP=

MTG_SECRET=
MTG_PORT=
# Currently active FakeTLS cover domain (rotated every 2h alongside XRAY_SNI)
MTG_COVER_DOMAIN=
# Comma-separated pool of FakeTLS cover domains for MTProxy fingerprint rotation
MTG_COVER_DOMAINS=
MTG_LINK=

XRAY_UUID=
XRAY_PRIVATE_KEY=
XRAY_PUBLIC_KEY=
XRAY_SHORT_ID=
XRAY_SNI=
XRAY_DEST=
XRAY_COVER_DOMAINS=
XRAY_ROTATE_HOURS=2
VLESS_URI=

SS_METHOD=2022-blake3-aes-256-gcm
SS_PORT=8388
SS_PASSWORD=
SS_URI=

IKE_PSK=
# Generated by generate-secrets.sh (e.g. vpn3f8a2c1b)
IKE_USER=
IKE_PASSWORD=
# Optional: FQDN resolving to this server, used as the IKEv2 server identity
# in the certificate. Improves reconnection on Apple clients. Leave empty to
# fall back to the server IP. Must be set before 'docker compose up -d'.
VPN_DNS_NAME=

# Secret URL token — share https://CREDENTIALS_DOMAIN/PAGE_TOKEN/ with users
PAGE_TOKEN=

# Domain for the nginx credentials page (required by setup-nginx.sh)
CREDENTIALS_DOMAIN=
# Webroot for the credentials page (default: /var/www/vpn)
CREDENTIALS_WEBROOT=/var/www/vpn
# Override nginx vhost file path (default: /etc/nginx/sites-available/vpn)
# NGINX_VHOST_PATH=/etc/nginx/sites-available/vpn
# Optional: email for Let's Encrypt SSL certificate expiry notifications
LETSENCRYPT_EMAIL=
