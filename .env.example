SERVER_IP=

MTG_SECRET=
MTG_PORT=
MTG_LINK=

XRAY_UUID=
XRAY_PRIVATE_KEY=
XRAY_PUBLIC_KEY=
XRAY_SHORT_ID=
XRAY_SNI=
XRAY_DEST=
XRAY_COVER_DOMAINS=
