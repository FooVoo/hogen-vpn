<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VPN / Telegram — подключение</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0f1117;
      color: #e2e8f0;
      font-family: system-ui, -apple-system, sans-serif;
      font-size: 15px;
      padding: 24px 16px 48px;
    }

    h1 {
      font-size: 20px;
      font-weight: 600;
      color: #f8fafc;
      margin-bottom: 24px;
      letter-spacing: -0.3px;
    }

    .cards {
      display: grid;
      gap: 20px;
      max-width: 700px;
    }

    .card {
      background: #1a1f2e;
      border: 1px solid #2d3448;
      border-radius: 12px;
      padding: 24px;
    }

    .card-header {
      display: flex;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 20px;
    }

    .card-title {
      font-size: 17px;
      font-weight: 600;
      color: #f1f5f9;
    }

    .card-subtitle {
      font-size: 13px;
      color: #64748b;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: opacity 0.15s;
    }
    .btn:hover { opacity: 0.85; }

    .btn-tg {
      background: #2481cc;
      color: #fff;
      margin-bottom: 20px;
    }

    .fields {
      display: grid;
      gap: 10px;
    }

    .field {
      display: grid;
      grid-template-columns: 120px 1fr auto;
      align-items: center;
      gap: 8px;
      background: #111827;
      border: 1px solid #1e2535;
      border-radius: 8px;
      padding: 10px 12px;
    }

    .field label {
      font-size: 12px;
      color: #64748b;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      white-space: nowrap;
    }

    .field code {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 13px;
      color: #a5f3fc;
      word-break: break-all;
      background: none;
    }

    .field.multiline {
      grid-template-columns: 120px 1fr;
      grid-template-rows: auto auto;
    }
    .field.multiline code {
      grid-column: 1 / -1;
      margin-top: 6px;
      padding-top: 8px;
      border-top: 1px solid #1e2535;
      font-size: 11.5px;
      color: #7dd3fc;
    }
    .field.multiline .copy-btn { display: none; }

    .copy-btn {
      background: #1e2535;
      border: 1px solid #2d3448;
      border-radius: 6px;
      color: #94a3b8;
      font-size: 11px;
      padding: 4px 8px;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.15s, color 0.15s;
      flex-shrink: 0;
    }
    .copy-btn:hover { background: #2d3448; color: #e2e8f0; }
    .copy-btn.copied { color: #4ade80; border-color: #4ade80; }

    .qr-row {
      display: flex;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 20px;
    }

    #qr-canvas {
      background: #fff;
      border-radius: 8px;
      padding: 8px;
      flex-shrink: 0;
    }

    .qr-hint {
      font-size: 13px;
      color: #64748b;
      line-height: 1.6;
    }
    .qr-hint strong { color: #94a3b8; display: block; margin-bottom: 6px; }
    .qr-hint .app-row { display: flex; align-items: baseline; gap: 8px; margin-bottom: 2px; }
    .qr-hint .app-name { color: #94a3b8; min-width: 70px; }
    .qr-hint a { color: #64748b; text-decoration: none; border-bottom: 1px dotted #334155; }
    .qr-hint a:hover { color: #94a3b8; }

    .vless-uri-copy {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #111827;
      border: 1px solid #1e2535;
      border-radius: 8px;
      padding: 10px 12px;
      margin-bottom: 20px;
    }
    .vless-uri-copy code {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 11.5px;
      color: #7dd3fc;
      word-break: break-all;
      flex: 1;
    }

    .divider {
      height: 1px;
      background: #1e2535;
      margin: 20px 0;
    }

    .section-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #475569;
      margin-bottom: 10px;
    }

    .rotation-meta {
      font-size: 12px;
      color: #334155;
      margin-top: 14px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .rotation-meta span { color: #475569; }

    .rotate-now-btn {
      background: none;
      border: 1px solid #334155;
      color: #475569;
      border-radius: 6px;
      padding: 3px 10px;
      font-size: 11px;
      cursor: pointer;
      white-space: nowrap;
      transition: border-color 0.15s, color 0.15s;
      flex-shrink: 0;
    }
    .rotate-now-btn:hover:not(:disabled) { border-color: #f59e0b; color: #f59e0b; }
    .rotate-now-btn:disabled { opacity: 0.45; cursor: not-allowed; }
    .rotate-now-btn.rn-ok  { border-color: #22c55e; color: #22c55e; }
    .rotate-now-btn.rn-err { border-color: #ef4444; color: #ef4444; }

    .status-badge {
      display: inline-block;
      padding: 4px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
      letter-spacing: .6px;
      margin-bottom: 18px;
    }
    .s-ok       { background: #14532d; color: #4ade80; }
    .s-degraded { background: #7f1d1d; color: #f87171; }
    .s-dim      { background: #1e2535; color: #475569; }
    .status-list { display: grid; gap: 0; }
    .status-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 8px 0;
      border-top: 1px solid #1e2535;
      font-size: 13px;
      color: #94a3b8;
    }
    .s-up   { color: #4ade80; font-weight: 600; }
    .s-down { color: #f87171; font-weight: 600; }

    @media (max-width: 500px) {
      .field { grid-template-columns: 100px 1fr; }
      .copy-btn { display: none; }
      .qr-row { flex-direction: column; }
    }
  </style>
</head>
<body>
  <h1>Подключение к VPN / Telegram</h1>

  <div class="cards">

    <!-- MTProxy card -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Telegram MTProxy</span>
        <span class="card-subtitle">только Telegram, встроено в приложение</span>
      </div>

      <a class="btn btn-tg" href="tg://proxy?server=${SERVER_IP}&port=${MTG_PORT}&secret=${MTG_SECRET}">
        &#8594; Подключить в Telegram
      </a>

      <div class="section-label">Параметры</div>
      <div class="fields">
        <div class="field">
          <label>Сервер</label>
          <code>${SERVER_IP}</code>
          <button class="copy-btn" data-copy="${SERVER_IP}">Копировать</button>
        </div>
        <div class="field">
          <label>Порт</label>
          <code>${MTG_PORT}</code>
          <button class="copy-btn" data-copy="${MTG_PORT}">Копировать</button>
        </div>
        <div class="field">
          <label>Секрет</label>
          <code>${MTG_SECRET}</code>
          <button class="copy-btn" data-copy="${MTG_SECRET}">Копировать</button>
        </div>
        <div class="field multiline">
          <label>Ссылка</label>
          <code id="mtg-link">${MTG_LINK}</code>
        </div>
      </div>
      <div class="rotation-meta">
        <span>Последнее обновление: ${MTG_LAST_ROTATED}</span>
        <button class="rotate-now-btn" id="rn-mtg" data-rotate="mtg">↻ Обновить</button>
      </div>
    </div>

    <!-- VLESS card -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">VLESS (VPN)</span>
        <span class="card-subtitle">весь трафик — нужно приложение</span>
      </div>

      <div class="qr-row">
        <div id="qr-canvas"></div>
        <div class="qr-hint">
          <strong>Сканируй QR-код в приложении:</strong>
          <div class="app-row">
            <span class="app-name">Android</span>
            <a href="https://play.google.com/store/apps/details?id=com.v2ray.ang" target="_blank">v2rayNG</a>
            <span style="color:#334155">·</span>
            <a href="https://github.com/2dust/v2rayNG/releases" target="_blank">GitHub</a>
          </div>
          <div class="app-row">
            <span class="app-name">iPhone</span>
            <a href="https://apps.apple.com/app/id6446814690" target="_blank">V2Box</a>
            <span style="color:#334155">·</span>
            <a href="https://apps.apple.com/app/shadowrocket/id932747118" target="_blank">Shadowrocket</a>
            <span style="color:#334155">·</span>
            <a href="https://apps.apple.com/app/streisand/id6450534064" target="_blank">Streisand</a>
          </div>
          <div class="app-row">
            <span class="app-name">Windows</span>
            <a href="https://github.com/2dust/v2rayN/releases" target="_blank">v2rayN</a>
          </div>
          <div class="app-row">
            <span class="app-name">macOS</span>
            <a href="https://apps.apple.com/app/hiddify-proxy-vpn/id6596777532" target="_blank">Hiddify</a>
            <span style="color:#334155">·</span>
            <a href="https://github.com/hiddify/hiddify-app/releases" target="_blank">GitHub</a>
          </div>
        </div>
      </div>

      <div class="section-label">URI (импорт по ссылке)</div>
      <div class="vless-uri-copy">
        <code id="vless-uri">${VLESS_URI}</code>
        <button class="copy-btn" data-copy-from="vless-uri">Копировать</button>
      </div>
      <a class="btn btn-tg" href="${VLESS_URI}" style="margin-bottom:20px;">&#8594; Открыть в приложении</a>
      <div class="qr-hint" style="margin-bottom:20px;">
        <strong>Важно:</strong>
        ${XRAY_ROTATION_MESSAGE}
      </div>
      <div class="rotation-meta">
        <span>Последнее обновление: ${XRAY_LAST_ROTATED}</span>
        <button class="rotate-now-btn" id="rn-xray" data-rotate="xray">↻ Обновить</button>
      </div>

      <div class="divider"></div>
      <div class="section-label">Параметры вручную</div>

      <div class="fields">
        <div class="field">
          <label>Адрес</label>
          <code>${SERVER_IP}</code>
          <button class="copy-btn" data-copy="${SERVER_IP}">Копировать</button>
        </div>
        <div class="field">
          <label>Порт</label>
          <code>8443</code>
          <button class="copy-btn" data-copy="8443">Копировать</button>
        </div>
        <div class="field">
          <label>UUID</label>
          <code>${XRAY_UUID}</code>
          <button class="copy-btn" data-copy="${XRAY_UUID}">Копировать</button>
        </div>
        <div class="field">
          <label>Flow</label>
          <code>xtls-rprx-vision</code>
          <button class="copy-btn" data-copy="xtls-rprx-vision">Копировать</button>
        </div>
        <div class="field">
          <label>Security</label>
          <code>reality</code>
          <button class="copy-btn" data-copy="reality">Копировать</button>
        </div>
        <div class="field">
          <label>SNI</label>
          <code>${XRAY_SNI}</code>
          <button class="copy-btn" data-copy="${XRAY_SNI}">Копировать</button>
        </div>
        <div class="field">
          <label>Fingerprint</label>
          <code>chrome</code>
          <button class="copy-btn" data-copy="chrome">Копировать</button>
        </div>
        <div class="field">
          <label>Public Key</label>
          <code>${XRAY_PUBLIC_KEY}</code>
          <button class="copy-btn" data-copy="${XRAY_PUBLIC_KEY}">Копировать</button>
        </div>
        <div class="field">
          <label>Short ID</label>
          <code>${XRAY_SHORT_ID}</code>
          <button class="copy-btn" data-copy="${XRAY_SHORT_ID}">Копировать</button>
        </div>
      </div>
    </div>

    <!-- Shadowsocks card -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Shadowsocks</span>
        <span class="card-subtitle">весь трафик — совместим с большинством клиентов</span>
      </div>

      <div class="qr-row">
        <div id="ss-qr-canvas"></div>
        <div class="qr-hint">
          <strong>Сканируй QR-код в приложении:</strong>
          <div class="app-row">
            <span class="app-name">Android</span>
            <a href="https://play.google.com/store/apps/details?id=com.v2ray.ang" target="_blank">v2rayNG</a>
            <span style="color:#334155">·</span>
            <a href="https://github.com/shadowsocks/shadowsocks-android/releases" target="_blank">SS Android</a>
          </div>
          <div class="app-row">
            <span class="app-name">iPhone</span>
            <a href="https://apps.apple.com/app/shadowrocket/id932747118" target="_blank">Shadowrocket</a>
            <span style="color:#334155">·</span>
            <a href="https://apps.apple.com/app/id6446814690" target="_blank">V2Box</a>
          </div>
          <div class="app-row">
            <span class="app-name">Windows</span>
            <a href="https://github.com/shadowsocks/shadowsocks-windows/releases" target="_blank">SS Windows</a>
            <span style="color:#334155">·</span>
            <a href="https://github.com/2dust/v2rayN/releases" target="_blank">v2rayN</a>
          </div>
          <div class="app-row">
            <span class="app-name">macOS</span>
            <a href="https://apps.apple.com/app/hiddify-proxy-vpn/id6596777532" target="_blank">Hiddify</a>
          </div>
        </div>
      </div>

      <div class="section-label">URI (импорт по ссылке)</div>
      <div class="vless-uri-copy">
        <code id="ss-uri">${SS_URI}</code>
        <button class="copy-btn" data-copy-from="ss-uri">Копировать</button>
      </div>

      <div class="divider"></div>
      <div class="section-label">Параметры вручную</div>
      <div class="fields">
        <div class="field">
          <label>Сервер</label>
          <code>${SERVER_IP}</code>
          <button class="copy-btn" data-copy="${SERVER_IP}">Копировать</button>
        </div>
        <div class="field">
          <label>Порт</label>
          <code>${SS_PORT}</code>
          <button class="copy-btn" data-copy="${SS_PORT}">Копировать</button>
        </div>
        <div class="field">
          <label>Метод</label>
          <code>${SS_METHOD}</code>
          <button class="copy-btn" data-copy="${SS_METHOD}">Копировать</button>
        </div>
        <div class="field">
          <label>Пароль</label>
          <code>${SS_PASSWORD}</code>
          <button class="copy-btn" data-copy="${SS_PASSWORD}">Копировать</button>
        </div>
      </div>
    </div>

    <!-- IKEv2 card -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">IKEv2 / IPSec</span>
        <span class="card-subtitle">встроен в iOS, macOS, Windows, Android</span>
      </div>

      <div class="qr-hint" style="margin-bottom:20px;">
        <strong>Клиентские приложения:</strong>
        <div class="app-row">
          <span class="app-name">iOS / macOS</span>
          <span style="color:#94a3b8">Встроенный VPN-клиент (Настройки → VPN)</span>
        </div>
        <div class="app-row">
          <span class="app-name">Android</span>
          <a href="https://play.google.com/store/apps/details?id=org.strongswan.android" target="_blank">strongSwan</a>
        </div>
        <div class="app-row">
          <span class="app-name">Windows</span>
          <span style="color:#94a3b8">Встроенный VPN-клиент (Настройки → Сеть → VPN)</span>
        </div>
      </div>

      <div class="section-label">Параметры подключения</div>
      <div class="fields" style="margin-bottom:20px;">
        <div class="field">
          <label>Сервер</label>
          <code>${SERVER_IP}</code>
          <button class="copy-btn" data-copy="${SERVER_IP}">Копировать</button>
        </div>
        <div class="field">
          <label>Тип</label>
          <code>IKEv2</code>
          <button class="copy-btn" data-copy="IKEv2">Копировать</button>
        </div>
        <div class="field">
          <label>Аутентификация</label>
          <code>EAP (логин + пароль)</code>
        </div>
        <div class="field">
          <label>Логин</label>
          <code>${IKE_USER}</code>
          <button class="copy-btn" data-copy="${IKE_USER}">Копировать</button>
        </div>
        <div class="field">
          <label>Пароль</label>
          <code>${IKE_PASSWORD}</code>
          <button class="copy-btn" data-copy="${IKE_PASSWORD}">Копировать</button>
        </div>
        <div class="field">
          <label>Pre-shared key</label>
          <code>${IKE_PSK}</code>
          <button class="copy-btn" data-copy="${IKE_PSK}">Копировать</button>
        </div>
      </div>

      <div class="divider"></div>
      <div class="section-label">Конфигурационный профиль</div>
      <div class="qr-hint">
        <strong>iOS / macOS .mobileconfig, Android .sswan:</strong>
        После первого запуска сервера выполни на нём команду для генерации профиля:
        <div style="margin-top:8px;">
          <code style="font-size:12px;color:#a5f3fc;word-break:break-all;">docker compose exec ipsec ikev2.sh --export-client client</code>
        </div>
        Файл появится в <code style="color:#a5f3fc;">./ipsec/data/</code> и включает CA-сертификат.
      </div>
    </div>

    <!-- WireGuard card -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">WireGuard</span>
        <span class="card-subtitle">быстрый, современный VPN — нужно приложение</span>
      </div>

      <div class="qr-row">
        <div id="wg-qr-canvas"></div>
        <div class="qr-hint">
          <strong>Сканируй QR-код или скачай конфиг:</strong>
          <div class="app-row">
            <span class="app-name">Android</span>
            <a href="https://play.google.com/store/apps/details?id=com.wireguard.android" target="_blank">WireGuard Android</a>
          </div>
          <div class="app-row">
            <span class="app-name">iPhone</span>
            <a href="https://apps.apple.com/app/wireguard/id1441195209" target="_blank">WireGuard iOS</a>
          </div>
          <div class="app-row">
            <span class="app-name">Windows</span>
            <a href="https://www.wireguard.com/install/" target="_blank">wireguard.com</a>
          </div>
          <div class="app-row">
            <span class="app-name">macOS</span>
            <a href="https://apps.apple.com/app/wireguard/id1451685025" target="_blank">WireGuard macOS</a>
          </div>
          <div class="app-row">
            <span class="app-name">Linux</span>
            <a href="https://www.wireguard.com/install/" target="_blank">wireguard.com</a>
          </div>
        </div>
      </div>

      <div class="section-label" style="margin-top:16px;">Конфигурационный файл</div>
      <div class="vless-uri-copy" style="margin-bottom:12px;">
        <code id="wg-client-config" style="white-space:pre;font-size:11px;">[Interface]
PrivateKey = ${WG_CLIENT_PRIVATE_KEY}
Address    = ${WG_CLIENT_IP}/24
DNS        = 1.1.1.1, 8.8.8.8
MTU        = 1420

[Peer]
PublicKey           = ${WG_SERVER_PUBLIC_KEY}
PresharedKey        = ${WG_PSK}
AllowedIPs          = 0.0.0.0/0, ::/0
Endpoint            = ${SERVER_IP}:${WG_PORT}
PersistentKeepalive = 25</code>
        <button class="copy-btn" data-copy-from="wg-client-config">Копировать</button>
      </div>
      <a class="btn btn-tg" href="wg-client.conf" download="wg-client.conf" style="margin-bottom:20px;">&#8595; Скачать wg-client.conf</a>

      <div class="divider"></div>
      <div class="section-label">Параметры вручную</div>
      <div class="fields">
        <div class="field">
          <label>Endpoint</label>
          <code>${SERVER_IP}:${WG_PORT}</code>
          <button class="copy-btn" data-copy="${SERVER_IP}:${WG_PORT}">Копировать</button>
        </div>
        <div class="field">
          <label>Порт</label>
          <code>${WG_PORT}</code>
          <button class="copy-btn" data-copy="${WG_PORT}">Копировать</button>
        </div>
        <div class="field">
          <label>Свой IP</label>
          <code>${WG_CLIENT_IP}/24</code>
          <button class="copy-btn" data-copy="${WG_CLIENT_IP}/24">Копировать</button>
        </div>
        <div class="field">
          <label>DNS</label>
          <code>1.1.1.1, 8.8.8.8</code>
          <button class="copy-btn" data-copy="1.1.1.1">Копировать</button>
        </div>
        <div class="field">
          <label>Public Key</label>
          <code>${WG_SERVER_PUBLIC_KEY}</code>
          <button class="copy-btn" data-copy="${WG_SERVER_PUBLIC_KEY}">Копировать</button>
        </div>
        <div class="field">
          <label>PSK</label>
          <code>${WG_PSK}</code>
          <button class="copy-btn" data-copy="${WG_PSK}">Копировать</button>
        </div>
        <div class="field">
          <label>Приватный ключ</label>
          <code>${WG_CLIENT_PRIVATE_KEY}</code>
          <button class="copy-btn" data-copy="${WG_CLIENT_PRIVATE_KEY}">Копировать</button>
        </div>
        <div class="field">
          <label>AllowedIPs</label>
          <code>0.0.0.0/0, ::/0</code>
        </div>
      </div>
    </div>

    <!-- Status card -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Статус сервисов</span>
        <span class="card-subtitle">обновляется каждые 60 с</span>
      </div>
      <div class="status-badge ${CHECK_OVERALL_CLASS}">${CHECK_OVERALL_LABEL}</div>
      <div class="status-list">
        <div class="status-row"><span>MTProxy  tcp:2083</span>${CHECK_MTG_TCP_HTML}</div>
        <div class="status-row"><span>MTProxy  container</span>${CHECK_MTG_CTR_HTML}</div>
        <div class="status-row"><span>VLESS    tcp:8443</span>${CHECK_XRAY_TCP_HTML}</div>
        <div class="status-row"><span>Xray     container</span>${CHECK_XRAY_CTR_HTML}</div>
        <div class="status-row"><span>Shadowsocks  tcp:8388</span>${CHECK_SS_TCP_HTML}</div>
        <div class="status-row"><span>IKEv2    container</span>${CHECK_IPSEC_CTR_HTML}</div>
        <div class="status-row"><span>WireGuard  container</span>${CHECK_WG_CTR_HTML}</div>
      </div>
      <div class="rotation-meta">Проверено: <span>${CHECK_TIMESTAMP}</span></div>
    </div>

  </div>

