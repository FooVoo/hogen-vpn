<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>VPN / Telegram — подключение</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0f1117;
      color: #e2e8f0;
      font-family: system-ui, -apple-system, sans-serif;
      font-size: 15px;
      padding: 24px 16px 48px;
    }

    h1 {
      font-size: 20px;
      font-weight: 600;
      color: #f8fafc;
      margin-bottom: 24px;
      letter-spacing: -0.3px;
    }

    .cards {
      display: grid;
      gap: 20px;
      max-width: 700px;
    }

    .card {
      background: #1a1f2e;
      border: 1px solid #2d3448;
      border-radius: 12px;
      padding: 24px;
    }

    .card-header {
      display: flex;
      align-items: baseline;
      gap: 12px;
      margin-bottom: 20px;
    }

    .card-title {
      font-size: 17px;
      font-weight: 600;
      color: #f1f5f9;
    }

    .card-subtitle {
      font-size: 13px;
      color: #64748b;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 18px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      cursor: pointer;
      border: none;
      transition: opacity 0.15s;
    }
    .btn:hover { opacity: 0.85; }

    .btn-tg {
      background: #2481cc;
      color: #fff;
      margin-bottom: 20px;
    }

    .fields {
      display: grid;
      gap: 10px;
    }

    .field {
      display: grid;
      grid-template-columns: 120px 1fr auto;
      align-items: center;
      gap: 8px;
      background: #111827;
      border: 1px solid #1e2535;
      border-radius: 8px;
      padding: 10px 12px;
    }

    .field label {
      font-size: 12px;
      color: #64748b;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      white-space: nowrap;
    }

    .field code {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 13px;
      color: #a5f3fc;
      word-break: break-all;
      background: none;
    }

    .field.multiline {
      grid-template-columns: 120px 1fr;
      grid-template-rows: auto auto;
    }
    .field.multiline code {
      grid-column: 1 / -1;
      margin-top: 6px;
      padding-top: 8px;
      border-top: 1px solid #1e2535;
      font-size: 11.5px;
      color: #7dd3fc;
    }
    .field.multiline .copy-btn { display: none; }

    .copy-btn {
      background: #1e2535;
      border: 1px solid #2d3448;
      border-radius: 6px;
      color: #94a3b8;
      font-size: 11px;
      padding: 4px 8px;
      cursor: pointer;
      white-space: nowrap;
      transition: background 0.15s, color 0.15s;
      flex-shrink: 0;
    }
    .copy-btn:hover { background: #2d3448; color: #e2e8f0; }
    .copy-btn.copied { color: #4ade80; border-color: #4ade80; }

    .qr-row {
      display: flex;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 20px;
    }

    #qr-canvas {
      background: #fff;
      border-radius: 8px;
      padding: 8px;
      flex-shrink: 0;
    }

    .qr-hint {
      font-size: 13px;
      color: #64748b;
      line-height: 1.6;
    }
    .qr-hint strong { color: #94a3b8; display: block; margin-bottom: 6px; }
    .qr-hint .app-row { display: flex; align-items: baseline; gap: 8px; margin-bottom: 2px; }
    .qr-hint .app-name { color: #94a3b8; min-width: 70px; }
    .qr-hint a { color: #64748b; text-decoration: none; border-bottom: 1px dotted #334155; }
    .qr-hint a:hover { color: #94a3b8; }

    .vless-uri-copy {
      display: flex;
      align-items: center;
      gap: 10px;
      background: #111827;
      border: 1px solid #1e2535;
      border-radius: 8px;
      padding: 10px 12px;
      margin-bottom: 20px;
    }
    .vless-uri-copy code {
      font-family: 'SF Mono', 'Fira Code', monospace;
      font-size: 11.5px;
      color: #7dd3fc;
      word-break: break-all;
      flex: 1;
    }

    .divider {
      height: 1px;
      background: #1e2535;
      margin: 20px 0;
    }

    .section-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #475569;
      margin-bottom: 10px;
    }

    @media (max-width: 500px) {
      .field { grid-template-columns: 100px 1fr; }
      .copy-btn { display: none; }
      .qr-row { flex-direction: column; }
    }
  </style>
</head>
<body>
  <h1>Подключение к VPN / Telegram</h1>

  <div class="cards">

    <!-- MTProxy card -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Telegram MTProxy</span>
        <span class="card-subtitle">только Telegram, встроено в приложение</span>
      </div>

      <a class="btn btn-tg" href="tg://proxy?server=${SERVER_IP}&port=${MTG_PORT}&secret=${MTG_SECRET}">
        &#8594; Подключить в Telegram
      </a>

      <div class="section-label">Параметры</div>
      <div class="fields">
        <div class="field">
          <label>Сервер</label>
          <code>${SERVER_IP}</code>
          <button class="copy-btn" onclick="copy(this, '${SERVER_IP}')">Копировать</button>
        </div>
        <div class="field">
          <label>Порт</label>
          <code>${MTG_PORT}</code>
          <button class="copy-btn" onclick="copy(this, '${MTG_PORT}')">Копировать</button>
        </div>
        <div class="field">
          <label>Секрет</label>
          <code>${MTG_SECRET}</code>
          <button class="copy-btn" onclick="copy(this, '${MTG_SECRET}')">Копировать</button>
        </div>
        <div class="field multiline">
          <label>Ссылка</label>
          <code id="mtg-link">${MTG_LINK}</code>
        </div>
      </div>
    </div>

    <!-- VLESS card -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">VLESS (VPN)</span>
        <span class="card-subtitle">весь трафик — нужно приложение</span>
      </div>

      <div class="qr-row">
        <div id="qr-canvas"></div>
        <div class="qr-hint">
          <strong>Сканируй QR-код в приложении:</strong>
          <div class="app-row">
            <span class="app-name">Android</span>
            <a href="https://play.google.com/store/apps/details?id=com.v2ray.ang" target="_blank">v2rayNG</a>
            <span style="color:#334155">·</span>
            <a href="https://github.com/2dust/v2rayNG/releases" target="_blank">GitHub</a>
          </div>
          <div class="app-row">
            <span class="app-name">iPhone</span>
            <a href="https://apps.apple.com/app/id6446814690" target="_blank">V2Box</a>
            <span style="color:#334155">·</span>
            <a href="https://apps.apple.com/app/shadowrocket/id932747118" target="_blank">Shadowrocket</a>
            <span style="color:#334155">·</span>
            <a href="https://apps.apple.com/app/streisand/id6450534064" target="_blank">Streisand</a>
          </div>
          <div class="app-row">
            <span class="app-name">Windows</span>
            <a href="https://github.com/2dust/v2rayN/releases" target="_blank">v2rayN</a>
          </div>
          <div class="app-row">
            <span class="app-name">macOS</span>
            <a href="https://apps.apple.com/app/hiddify-proxy-vpn/id6596777532" target="_blank">Hiddify</a>
            <span style="color:#334155">·</span>
            <a href="https://github.com/hiddify/hiddify-app/releases" target="_blank">GitHub</a>
          </div>
        </div>
      </div>

      <div class="section-label">URI (импорт по ссылке)</div>
      <div class="vless-uri-copy">
        <code id="vless-uri">${VLESS_URI}</code>
        <button class="copy-btn" onclick="copy(this, document.getElementById('vless-uri').textContent)">Копировать</button>
      </div>
      <a class="btn btn-tg" href="${VLESS_URI}" style="margin-bottom:20px;">&#8594; Открыть в приложении</a>

      <div class="divider"></div>
      <div class="section-label">Параметры вручную</div>

      <div class="fields">
        <div class="field">
          <label>Адрес</label>
          <code>${SERVER_IP}</code>
          <button class="copy-btn" onclick="copy(this, '${SERVER_IP}')">Копировать</button>
        </div>
        <div class="field">
          <label>Порт</label>
          <code>8443</code>
          <button class="copy-btn" onclick="copy(this, '8443')">Копировать</button>
        </div>
        <div class="field">
          <label>UUID</label>
          <code>${XRAY_UUID}</code>
          <button class="copy-btn" onclick="copy(this, '${XRAY_UUID}')">Копировать</button>
        </div>
        <div class="field">
          <label>Flow</label>
          <code>xtls-rprx-vision</code>
          <button class="copy-btn" onclick="copy(this, 'xtls-rprx-vision')">Копировать</button>
        </div>
        <div class="field">
          <label>Security</label>
          <code>reality</code>
          <button class="copy-btn" onclick="copy(this, 'reality')">Копировать</button>
        </div>
        <div class="field">
          <label>SNI</label>
          <code>${XRAY_SNI}</code>
          <button class="copy-btn" onclick="copy(this, '${XRAY_SNI}')">Копировать</button>
        </div>
        <div class="field">
          <label>Fingerprint</label>
          <code>chrome</code>
          <button class="copy-btn" onclick="copy(this, 'chrome')">Копировать</button>
        </div>
        <div class="field">
          <label>Public Key</label>
          <code>${XRAY_PUBLIC_KEY}</code>
          <button class="copy-btn" onclick="copy(this, '${XRAY_PUBLIC_KEY}')">Копировать</button>
        </div>
        <div class="field">
          <label>Short ID</label>
          <code>${XRAY_SHORT_ID}</code>
          <button class="copy-btn" onclick="copy(this, '${XRAY_SHORT_ID}')">Копировать</button>
        </div>
      </div>
    </div>

  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"
    integrity="sha512-CNgIRecGo7nphbeZ04Sc13ka07paqdeTu0WR1IM4kNcpmBAUSHSi2jPeeaHnLj3GlWPjHFzXQy0f5EWFVVoaA=="
    crossorigin="anonymous"></script>
  <script>
    // QR code
    try {
      new QRCode(document.getElementById('qr-canvas'), {
        text: document.getElementById('vless-uri').textContent.trim(),
        width: 160,
        height: 160,
        colorDark: '#000000',
        colorLight: '#ffffff',
        correctLevel: QRCode.CorrectLevel.M
      });
    } catch (e) {
      document.getElementById('qr-canvas').textContent = '(QR недоступен)';
    }

    // Copy to clipboard
    function copy(btn, text) {
      navigator.clipboard.writeText(text).then(function () {
        var orig = btn.textContent;
        btn.textContent = 'Скопировано';
        btn.classList.add('copied');
        setTimeout(function () {
          btn.textContent = orig;
          btn.classList.remove('copied');
        }, 1500);
      });
    }
  </script>
</body>
</html>
