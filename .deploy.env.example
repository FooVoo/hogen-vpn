# Local deploy overrides — copy to .deploy.env and source before running deploy.sh
# These are NOT synced to the server.
#
# Usage:
#   source .deploy.env && ./deploy.sh
# Or export individually:
#   DEPLOY_HOST=user@myserver.com ./deploy.sh

# SSH target: user@hostname (default: root@universal.ramilkarimov.me)
DEPLOY_HOST=root@universal.ramilkarimov.me

# Remote directory where the project lives (default: /opt/vpn)
DEPLOY_REMOTE_DIR=/opt/vpn

# Local SSH private key path (default: ~/.ssh/vpn_deploy)
DEPLOY_KEY=~/.ssh/vpn_deploy
